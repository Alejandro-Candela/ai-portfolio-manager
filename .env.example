# ── Application ──
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# ── Database (Azure PostgreSQL Flexible Server) ──
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/portfolio_manager
DATABASE_POOL_SIZE=10

# ── Azure AI Foundry ──
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-api-key
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_GPT4O_DEPLOYMENT=gpt-4o
AZURE_OPENAI_O3MINI_DEPLOYMENT=o3-mini

# ── Azure AI Search ──
AZURE_SEARCH_ENDPOINT=https://your-search.search.windows.net
AZURE_SEARCH_ADMIN_KEY=your-admin-key
AZURE_SEARCH_INDEX_PREFIX=portfolio

# ── Microsoft Entra ID (Auth) ──
AZURE_AD_TENANT_ID=your-tenant-id
AZURE_AD_CLIENT_ID=your-client-id
AZURE_AD_AUDIENCE=api://your-client-id

# ── LangSmith (Observability) ──
LANGSMITH_API_KEY=your-langsmith-key
LANGSMITH_PROJECT=ai-portfolio-manager
LANGCHAIN_TRACING_V2=true

# ── OpenTelemetry ──
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=ai-portfolio-manager

# ── Frontend ──
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_COPILOTKIT_URL=/api/copilotkit

# ── Dev mode ──
DEV_AUTH_BYPASS=true
DEV_TENANT_ID=dev-tenant-001
